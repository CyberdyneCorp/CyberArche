# CyberArche backend configuration (services read CYBERARCHE_* from env/.env).
# Copy to .env and fill the secrets — never commit real values.

# Store: "postgres" for real deployments, "memory" for the sample runtime.
CYBERARCHE_BACKEND=postgres
CYBERARCHE_DATABASE_URL=postgresql://cyberarche:cyberarche@localhost:5544/cyberarche

# CyberdyneAuth (SSO + service-to-service).
CYBERARCHE_AUTH_BASE_URL=https://auth.backend.coolify.cyberdynecorp.ai
# OAuth client "cyberarche-backend" (confidential, client_credentials):
CYBERARCHE_AUTH_CLIENT_ID=cyb_lyoEz3tbJKwQyPA7
CYBERARCHE_AUTH_CLIENT_SECRET=<client secret — shown once at registration>
# The public SPA client for OIDC auth-code + PKCE is "cyberarche-web"
# (cyb_Tnt2GuKPgN16B5nz); it has no secret.

# CyberdyneRAG (accepts CyberdyneAuth bearer tokens; leave token empty to
# use client-credentials from the auth client above).
CYBERARCHE_RAG_BASE_URL=https://cyberrag.coolify.cyberdynecorp.ai
CYBERARCHE_RAG_API_TOKEN=
CYBERARCHE_RAG_WEBHOOK_SECRET=<random shared secret for task callbacks>

# LLM provider: "anthropic" | "openai" | "local" (OpenAI-compatible base_url).
CYBERARCHE_LLM_PROVIDER=anthropic
CYBERARCHE_LLM_MODEL=claude-sonnet-5
CYBERARCHE_LLM_API_KEY=<provider api key>
CYBERARCHE_LLM_BASE_URL=

# Connector credential encryption (Fernet key material).
CYBERARCHE_CONNECTOR_SECRET_KEY=<long random string>

# Multi-replica infrastructure (empty = single-process in-memory).
CYBERARCHE_REDIS_URL=
CYBERARCHE_BLOB_DIR=./data/blobs
